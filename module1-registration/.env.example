# ── RahatPay Module 1 — Environment Configuration ──────────────────────────
# Copy this to .env and fill in your values.
# Never commit .env to version control.

# ── Application ──────────────────────────────────────────────────────────────
DEBUG=true
ENVIRONMENT=development
APP_VERSION=1.0.0

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://rahatpay:rahatpay@localhost:5432/rahatpay
DB_ECHO=false

# ── Firebase ──────────────────────────────────────────────────────────────────
# Set FIREBASE_MOCK_MODE=false in production and provide real credentials path
FIREBASE_MOCK_MODE=true
FIREBASE_CREDENTIALS_PATH=

# ── Module 2 Integration ──────────────────────────────────────────────────────
# Set to false once module2-risk-engine is available in the monorepo
MODULE2_MOCK_MODE=true
